{
  "manifest_version": 3,
  "name": "Automatic Bid Record",
  "version": "0.3.0",
  "description": "Saves each completed job application to IndexedDB (AutomaticBidRecord), then export that database to an Excel file.",
  "permissions": ["storage", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Bid history"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extractors.js", "content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
